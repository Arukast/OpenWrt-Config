# =============================================================================
# OpenWrt Setup Configuration File
# Copy this file to setup.conf and edit the values before running the script.
# =============================================================================

# --- System ---
HOSTNAME="OpenWrt-WISP"          # Options: Any valid hostname string (no spaces)
TIMEZONE="WIB-7"                 # Options: WIB-7, WITA-8, WIT-9, UTC, EST5EDT, etc.
ZONENAME="Asia/Jakarta"          # Options: Asia/Jakarta, Asia/Makassar, UTC, America/New_York
LAN_IP="192.168.11.1"            # Options: Any private IP (e.g., 192.168.x.1). Avoids conflict with 192.168.1.1
LAN_NETMASK="255.255.255.0"      # Options: 255.255.255.0 (/24) is standard

# --- Connection Mode ---
CONNECTION_MODE="WISP"           # Options: WISP, WIRED. WISP uses Wi-Fi as WAN. WIRED uses physical WAN port.

# --- Wireless WAN Interface (WISP/STA) ---
WWAN_IFACE="phy0-sta0"           # Options: phy0-sta0, wlan0 (Check via 'iw dev')

# --- Radio Names ---
RADIO_2G="radio0"                # Options: radio0, radio1 (Check via 'uci show wireless')
RADIO_5G="radio1"                # Options: radio1, radio0. Leave empty if no 5 GHz radio: RADIO_5G=""

# --- Wireless Config ---
WIFI_SSID_2G="OpenWrt-WISP-2G"   # Options: Any string
WIFI_SSID_5G="OpenWrt-WISP-5G"   # Options: Any string
WIFI_KEY="CHANGE_ME_SUPER_SECRET_KEY" # REQUIRED: Change this! (Must be 8-63 characters)

CH_2G="6"                        # Options: 1, 6, 11 (Auto is not recommended for WISP)
# Options for HTMODE_2G: HT20, HT40 (WiFi N) | VHT20, VHT40 (WiFi AC) | HE20, HE40 (WiFi AX)
HTMODE_2G="HT20"                 
TXPWR_2G="13"                    # Options: 1-30 (Depends on country regulatory domain)

CH_5G="36"                      # Options: 36, 40, 44, 48, 149, 153, 157, 161
# Options for HTMODE_5G: VHT20, VHT40, VHT80, VHT160 (WiFi AC) | HE20, HE40, HE80, HE160 (WiFi AX)
HTMODE_5G="VHT80"                 
TXPWR_5G="17"                    # Options: 1-30 (Depends on country regulatory domain)

COUNTRY="ID"                     # Options: ID, US, JP, DE, etc. (ISO 3166-1 alpha-2 code)
LAN_PORTS=""                     # Options: "1 2 3 4" or empty to keep defaults

# --- SQM CAKE Bandwidth (kbps) ---
DL_KBPS="23000"                  # Options: Set to 90-95% of your WISP download speed (0 to disable)
UL_KBPS="11000"                  # Options: Set to 90-95% of your WISP upload speed (0 to disable)

# --- SQM MTU / Overhead ---
SQM_OVERHEAD="44"                # Options: 44 (Ethernet), 34 (VDSL2), 0 (none)
SQM_LINKLAYER="ethernet"         # Options: ethernet, atm, none
SQM_MTU="1480"                   # Options: 1500 (Standard), 1492 (PPPoE), 1480 (Tailscale/WireGuard)

# --- ZRAM ---
ZRAM_MB="128"                    # Options: Half of your total RAM (e.g., 64, 128, 256). Empty to disable
# Options: lzo -> lzo-rle -> lz4 -> zstd (Ordered from fastest/lowest CPU to best compression/highest CPU)
# Note: zstd gives the best compression but can cause high CPU load/lag on weak routers. lzo-rle is the safest fast default.
ZRAM_ALGO="lzo-rle"              

# --- DNS over HTTPS ---
DOH_PRIMARY_BOOTSTRAP="1.1.1.1,1.0.0.1,2606:4700:4700::1111,2606:4700:4700::1001"          # Options: Comma separated DNS IPs
DOH_PRIMARY_URL="https://cloudflare-dns.com/dns-query" # Options: Any DoH resolver URL
DOH_PRIMARY_PORT="5053"                          # Options: Local port to listen on

DOH_SECONDARY_BOOTSTRAP="9.9.9.9,149.112.112.112,2620:fe::fe,2620:fe::9" # Options: Comma separated DNS IPs
DOH_SECONDARY_URL="https://dns.quad9.net/dns-query"    # Options: Any DoH resolver URL
DOH_SECONDARY_PORT="5054"                        # Options: Local port to listen on
IPV6_DNS_PRIMARY="2606:4700:4700::1111"          # Options: Any IPv6 DNS address
IPV6_DNS_SECONDARY="2620:fe::fe"                 # Options: Any IPv6 DNS address

# --- NTP Servers ---
NTP_SERVERS="0.id.pool.ntp.org 1.id.pool.ntp.org 2.id.pool.ntp.org 3.id.pool.ntp.org" # Options: Space separated NTP servers

# --- Feature Toggles (1=enabled, 0=disabled) ---
ENABLE_TAILSCALE=1               # Options: 1 (enable), 0 (disable)
ENABLE_ADBLOCK_LEAN=1            # Options: 1 (enable), 0 (disable)
ENABLE_WANUSB_ZONE=0             # Options: 1 (enable), 0 (disable)
ENABLE_IPV6=0                    # Options: 1 (Enable IPv6), 0 (disable IPv6)
USE_WAN_AS_LAN=1                 # Options: 1 (enable), 0 (disable). Repurposes WAN port as LAN in WISP mode.

# --- WireGuard over IPv6 Config ---
ENABLE_WIREGUARD=0                # Options: 1 (enable), 0 (disable)
WG_PORT="51820"                   # Options: Standard WireGuard UDP Port (usually 51820)
WG_IPV4_SUBNET="10.8.0.1/24"      # Internal tunnel IPv4 address/subnet
WG_IPV6_SUBNET="fd11:2233:4455::1/64" # Internal tunnel IPv6 address/subnet
WG_CLIENTS="phone laptop"         # List of client peers to pre-configure (space-separated)

# --- DuckDNS DDNS (Recommended for Dynamic IPv6) ---
ENABLE_WG_DDNS=0                 # Options: 1 (enable), 0 (disable). Keeps domain updated with IPv6 address.
WG_DDNS_DOMAIN="yourdomain.duckdns.org" # Your custom DuckDNS domain name
WG_DDNS_TOKEN="your-duckdns-token"      # Your DuckDNS API token
