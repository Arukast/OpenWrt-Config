#!/bin/sh
# File: /etc/hotplug.d/iface/99-wisp-notify

# Load config & lang
CONF="/etc/telegram.conf"
[ -f "$CONF" ] || CONF="$(dirname "$0")/telegram.conf"
[ -f "$CONF" ] || exit 0
. "$CONF"

LANG_FILE="$(dirname "$0")/lang/${LANG:-en}.sh"
[ -f "$LANG_FILE" ] && . "$LANG_FILE" || . "$(dirname "$0")/lang/en.sh"

IFACE="wwan"
DOWN_TIME_FILE="/tmp/wisp_down_time"

if [ "$INTERFACE" = "$IFACE" ]; then
    if [ "$ACTION" = "ifdown" ]; then
        date +%s > "$DOWN_TIME_FILE"
    
    elif [ "$ACTION" = "ifup" ]; then
        IP=$(ifstatus "$IFACE" | jsonfilter -e '@["ipv4-address"][0].address' 2>/dev/null)
        [ -z "$IP" ] && IP="unknown"
        
        WWAN_DEV=$(uci -q get network.wwan.device || echo "phy0-sta0")
        SIGNAL=$(iw dev "$WWAN_DEV" link 2>/dev/null | grep signal | awk '{print $2}')
        [ -z "$SIGNAL" ] && SIGNAL="unknown"

        if [ -f "$DOWN_TIME_FILE" ]; then
            DOWN_TIME=$(cat "$DOWN_TIME_FILE")
            UP_TIME=$(date +%s)
            DURATION=$((UP_TIME - DOWN_TIME))
            MINUTES=$((DURATION / 60))
            SECONDS=$((DURATION % 60))
            
            rm -f "$DOWN_TIME_FILE"
            
            MSG=$(printf "$MSG_WISP_RECOVER" "$MINUTES" "$SECONDS" "$IP" "$SIGNAL")
            /usr/bin/telegram_notify.sh "NETWORK" "$MSG"
        else
            MSG=$(printf "$MSG_WISP_CONNECTED" "$IP" "$SIGNAL")
            /usr/bin/telegram_notify.sh "NETWORK" "$MSG"
        fi
    fi
fi
